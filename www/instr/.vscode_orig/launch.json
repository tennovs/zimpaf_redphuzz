{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Listen for XDebug",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "${workspaceFolder}": "${workspaceFolder}"
            },
            "hostname": "127.0.0.1",
            "localSourceRoot": "${workspaceFolder}",
            "remoteSourceRoot": "/var/www/instr"
        }
    ]
}
